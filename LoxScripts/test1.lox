fun thrice(fn) {
  for (var i = 1; i <= 3; i = i + 1) {
    fn(i);
  }
}

thrice(fun (a) {
  print a;
});

var daimond = fun (a){
    print a * 2;
};
thrice(daimond);

var f = fun (a) {
  return a;
};
print f(42);

fun multiplier(x) {
  return fun (y) {
    return x * y;
  };
}

var double = multiplier(2);
var triple = multiplier(3);

print double(5);
print triple(5);

for (var i = 1; i <= 5; i = i + 1) {
  print i;
}

